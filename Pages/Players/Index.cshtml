@page
@model CheckerZ_Server.Pages.Players.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>
<div class="row mt-4">
    @*Filters the data on post*@
    <form method="post">
        <div class="col-3">
            <button asp-page="" asp-page-handler = "ShowPlayerData" type="submit">Show Players who played</button>
        </div>
    </form>
    @*Move to games page*@
    <div class="col-3">
        <a asp-page="/Games/Index" class="btn btn-primary btn">Show Games</a>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Players[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Players[0].PhoneNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Players[0].Country)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Players) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PhoneNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Country)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
